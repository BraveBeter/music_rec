# ============ Database ============
MYSQL_ROOT_PASSWORD=music_rec_root_2026
MYSQL_DATABASE=music_rec
MYSQL_USER=music_app
MYSQL_PASSWORD=music_app_pass_2026
# Docker 内部服务名（compose 中 service 名）
MYSQL_HOST=musicrec_mysql
MYSQL_PORT=3306

# ============ Redis ============
# Docker 内部服务名
REDIS_HOST=musicrec_redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_music_2026

# ============ JWT ============
JWT_SECRET_KEY=super-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ App ============
APP_NAME=MusicRec
APP_ENV=development
APP_DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============ Frontend ============
# 本地开发时访问宿主机端口 18000；Docker 内部走 musicrec_backend:8000
VITE_API_BASE_URL=http://localhost:18000/api/v1

# ============ 本地开发覆盖（在宿主机直接运行 uvicorn 时使用） ============
# 把下面两行的注释去掉，或者在启动命令中手动 export
# MYSQL_HOST=localhost
# MYSQL_PORT=13307
# REDIS_HOST=localhost
# REDIS_PORT=16379

# ============ Jamendo API (Full Streaming) ============
JAMENDO_CLIENT_ID=f2b6da64
# 把下面两行的注释去掉，或者在启动命令中手动 export
# MYSQL_HOST=localhost
# MYSQL_PORT=13307
# REDIS_HOST=localhost
# REDIS_PORT=16379
